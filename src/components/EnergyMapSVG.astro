---
/**
 * EnergyMapSVG — stylized schematic of UA ↔ EU energy interconnections.
 * Simplified outlines of Ukraine and neighbor countries with pulsing connection dots.
 * Pure CSS animations, theme-reactive via CSS custom properties.
 */
---

<div class="energy-map" aria-hidden="true">
  <svg viewBox="0 0 440 320" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto max-w-[440px]">
    {/* Ukraine — center, large simplified outline */}
    <path
      d="M180 100 L220 85 L270 90 L310 105 L330 120 L340 150 L335 180 L310 200 L280 210 L250 215 L220 220 L190 215 L160 200 L145 175 L150 145 L160 120 Z"
      class="country-ua"
      stroke-width="1.5"
    />
    <text x="235" y="160" class="country-label label-ua" text-anchor="middle">UA</text>

    {/* Poland — top-left */}
    <path
      d="M100 50 L140 40 L165 50 L170 75 L155 90 L130 95 L105 85 L95 70 Z"
      class="country-neighbor"
      stroke-width="1"
    />
    <text x="132" y="72" class="country-label label-sm" text-anchor="middle">PL</text>

    {/* Slovakia — left-center */}
    <path
      d="M95 100 L130 95 L155 100 L158 115 L145 125 L115 125 L95 115 Z"
      class="country-neighbor"
      stroke-width="1"
    />
    <text x="128" y="114" class="country-label label-sm" text-anchor="middle">SK</text>

    {/* Hungary — bottom-left */}
    <path
      d="M85 130 L115 125 L140 130 L150 150 L145 170 L125 180 L100 175 L85 155 Z"
      class="country-neighbor"
      stroke-width="1"
    />
    <text x="118" y="156" class="country-label label-sm" text-anchor="middle">HU</text>

    {/* Romania — bottom */}
    <path
      d="M155 200 L185 215 L210 225 L230 240 L215 260 L185 265 L155 255 L140 235 L140 215 Z"
      class="country-neighbor"
      stroke-width="1"
    />
    <text x="186" y="244" class="country-label label-sm" text-anchor="middle">RO</text>

    {/* Moldova — right */}
    <path
      d="M310 130 L335 125 L350 140 L350 170 L340 185 L320 185 L310 170 Z"
      class="country-neighbor"
      stroke-width="1"
    />
    <text x="330" y="160" class="country-label label-sm" text-anchor="middle">MD</text>

    {/* Connection lines */}
    <line x1="155" y1="90" x2="170" y2="105" class="connection-line" />
    <line x1="145" y1="120" x2="158" y2="125" class="connection-line" />
    <line x1="145" y1="165" x2="155" y2="175" class="connection-line" />
    <line x1="190" y1="215" x2="185" y2="225" class="connection-line" />
    <line x1="310" y1="155" x2="330" y2="150" class="connection-line" />

    {/* Pulsing dots at interconnection points */}
    <circle cx="162" cy="97" r="4" class="pulse-dot dot-1" />
    <circle cx="162" cy="97" r="4" class="pulse-ring dot-1" />

    <circle cx="151" cy="122" r="4" class="pulse-dot dot-2" />
    <circle cx="151" cy="122" r="4" class="pulse-ring dot-2" />

    <circle cx="150" cy="170" r="4" class="pulse-dot dot-3" />
    <circle cx="150" cy="170" r="4" class="pulse-ring dot-3" />

    <circle cx="187" cy="220" r="4" class="pulse-dot dot-4" />
    <circle cx="187" cy="220" r="4" class="pulse-ring dot-4" />

    <circle cx="320" cy="152" r="4" class="pulse-dot dot-5" />
    <circle cx="320" cy="152" r="4" class="pulse-ring dot-5" />

    {/* Energy flow arrows along connections */}
    <circle cx="164" cy="100" r="2" class="flow-particle flow-1" />
    <circle cx="148" cy="125" r="2" class="flow-particle flow-2" />
    <circle cx="152" cy="173" r="2" class="flow-particle flow-3" />
    <circle cx="188" cy="218" r="2" class="flow-particle flow-4" />
    <circle cx="315" cy="153" r="2" class="flow-particle flow-5" />
  </svg>
</div>

<style>
  .energy-map {
    opacity: 0.85;
  }

  /* Country fills */
  .country-ua {
    fill: var(--color-accent-subtle);
    stroke: var(--color-accent);
  }

  .country-neighbor {
    fill: var(--color-bg-secondary);
    stroke: var(--color-border);
  }

  /* Labels */
  .country-label {
    font-family: var(--font-display);
    font-weight: 700;
    fill: var(--color-text-muted);
  }

  .label-ua {
    font-size: 16px;
    fill: var(--color-accent);
  }

  .label-sm {
    font-size: 11px;
  }

  /* Connection lines */
  .connection-line {
    stroke: var(--color-accent);
    stroke-width: 1.5;
    stroke-dasharray: 4 3;
    opacity: 0.4;
  }

  /* Pulsing dots at border crossings */
  .pulse-dot {
    fill: var(--color-accent);
  }

  .pulse-ring {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 1.5;
    opacity: 0;
  }

  /* Flow particles */
  .flow-particle {
    fill: var(--color-accent);
    opacity: 0;
  }

  /* Animations */
  @media (prefers-reduced-motion: no-preference) {
    .pulse-ring {
      animation: pulseRing 2.5s ease-out infinite;
    }

    .dot-2 .pulse-ring, .pulse-ring.dot-2 { animation-delay: 0.5s; }
    .dot-3 .pulse-ring, .pulse-ring.dot-3 { animation-delay: 1.0s; }
    .dot-4 .pulse-ring, .pulse-ring.dot-4 { animation-delay: 1.5s; }
    .dot-5 .pulse-ring, .pulse-ring.dot-5 { animation-delay: 2.0s; }

    .flow-particle {
      animation: flowPulse 3s ease-in-out infinite;
    }

    .flow-2 { animation-delay: 0.6s; }
    .flow-3 { animation-delay: 1.2s; }
    .flow-4 { animation-delay: 1.8s; }
    .flow-5 { animation-delay: 2.4s; }

    @keyframes pulseRing {
      0% {
        r: 4;
        opacity: 0.6;
      }
      100% {
        r: 14;
        opacity: 0;
      }
    }

    @keyframes flowPulse {
      0%, 100% { opacity: 0; }
      50% { opacity: 0.8; }
    }
  }
</style>
