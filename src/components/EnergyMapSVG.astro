---
/**
 * EnergyMapSVG — realistic country outlines of UA ↔ EU energy interconnections.
 * Country paths from Natural Earth (public domain) via simple-world-map.
 * Pure CSS animations, theme-reactive via CSS custom properties.
 */
---

<div class="energy-map" aria-hidden="true">
  <svg viewBox="434 375 63 43" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
    {/* Poland */}
    <path
      d="M457.109,390.184l0.733,1.348l0.174,1.435l-0.604,1.392l-1.383,2.664l-1.167,0.526l-1.514-0.657l-0.908,0.043l-2.204,0.83l-2.506-0.742l-4.062-2.879l-3.978-2.135l-1.6-2.438l-0.303-5.75l3.112-2.705l4.062-1.35l1.328-0.138l0.315,1.007l1.725,0.692l4.766,0.09l1.47-0.043l2.421,3.708l-0.604,1.521l0.259,1.789Z"
      class="country-neighbor"
      stroke-width="0.7"
    />
    <text x="446" y="388" class="country-label label-sm" text-anchor="middle">PL</text>

    {/* Slovakia */}
    <path
      d="M443.607,400.875l0.597,0.527l0.077,0.898l6.596-0.146l4.875-2.102l-0.077-2.135l-0.934,0.415l-1.34-0.718l-0.821-0.035l-2.161,0.865l-2.938-0.709Z"
      class="country-neighbor"
      stroke-width="0.7"
    />
    <text x="449" y="400.5" class="country-label label-xs" text-anchor="middle">SK</text>

    {/* Hungary */}
    <path
      d="M444.386,403.01l-1.003,1.573l0.078,2.403l1.599,0.82l4.919,0.147l6.854-5.774l0.034-1.279l-0.742-0.371l-4.953,2.248Z"
      class="country-neighbor"
      stroke-width="0.7"
    />
    <text x="448" y="405.5" class="country-label label-xs" text-anchor="middle">HU</text>

    {/* Romania */}
    <path
      d="M457.731,401.281l-0.226,1.279l-5.005,4.166l4.184,6.137l2.682,1.877h4.823l1.591-1.331l2.135-0.276l1.591,0.959l2.818-3.207l-0.545-1.607l-2.861-0.734l-1.953-0.095l0.094-2.749l-2.593-4.08Z"
      class="country-neighbor"
      stroke-width="0.7"
    />
    <text x="459" y="410" class="country-label label-sm" text-anchor="middle">RO</text>

    {/* Ukraine — main, accent fill */}
    <path
      d="M460.662,388.791l-2.507,1.409l0.622,2.663l-2.316,4.884l0.02,2.151l1.089,0.691l6.983,0.346l1.954-1.615l2.092,0.699l2.999,4.002l-2.194,3.942l2.61,0.761l3.414-3.933l1.954,0.354l1.815,1.262l-1.601,2.109l2.161,3.371h2.299l1.185-2.248l2.438-0.494l0.069-1.823l-4.529-0.7l0.14-1.963h4.391l4.737-3.794l2.092-1.824l0.345-5.757l-9.336-0.838l-3.829-5.402l-2.646-0.908l-3.207,0.139l-1.443,3.569l-6.57,0.087l-2.135-0.986Z"
      class="country-ua"
      stroke-width="0.8"
    />
    <text x="472" y="398" class="country-label label-ua" text-anchor="middle">UA</text>

    {/* Connection lines — dashed, placed at actual SVG border contact points */}
    {/* PL ↔ UA: 750 kV Rzeszów–Khmelnytskyi */}
    <line x1="453" y1="391" x2="462" y2="397" class="connection-line" />
    {/* SK ↔ UA: 400 kV Mukachevo–V. Kapušany */}
    <line x1="451" y1="400" x2="460" y2="399" class="connection-line" />
    {/* HU ↔ UA: 750 kV Albertirsa–Zakhidnoukrainska */}
    <line x1="452" y1="403" x2="461" y2="399" class="connection-line" />
    {/* RO ↔ UA: Burshtyn island 220/400 kV */}
    <line x1="458" y1="405" x2="466" y2="398" class="connection-line" />

    {/* Pulsing dots — positioned exactly at SVG border contact midpoints */}
    {/* PL ↔ UA: border midpoint (457.7, 394.5) */}
    <circle cx="457.7" cy="394.5" r="0.8" class="pulse-dot dot-1" />
    <circle cx="457.7" cy="394.5" r="0.8" class="pulse-ring dot-1" />

    {/* SK ↔ UA: border midpoint (456.1, 399.5) */}
    <circle cx="456.1" cy="399.5" r="0.8" class="pulse-dot dot-2" />
    <circle cx="456.1" cy="399.5" r="0.8" class="pulse-ring dot-2" />

    {/* HU ↔ UA: border midpoint (457, 400.6) */}
    <circle cx="457" cy="400.6" r="0.8" class="pulse-dot dot-3" />
    <circle cx="457" cy="400.6" r="0.8" class="pulse-ring dot-3" />

    {/* RO ↔ UA: border midpoint (462.1, 401.2) */}
    <circle cx="462.1" cy="401.2" r="0.8" class="pulse-dot dot-4" />
    <circle cx="462.1" cy="401.2" r="0.8" class="pulse-ring dot-4" />

    {/* Energy flow particles — on the EU-country side of each line */}
    <circle cx="455" cy="392.5" r="0.5" class="flow-particle flow-1" />
    <circle cx="453" cy="399.8" r="0.5" class="flow-particle flow-2" />
    <circle cx="454" cy="402" r="0.5" class="flow-particle flow-3" />
    <circle cx="460" cy="403.5" r="0.5" class="flow-particle flow-4" />
  </svg>
</div>

<style>
  .energy-map {
    opacity: 0.9;
  }

  /* Country fills */
  .country-ua {
    fill: var(--color-accent-subtle);
    stroke: var(--color-accent);
  }

  .country-neighbor {
    fill: var(--color-bg-secondary);
    stroke: var(--color-border-hover);
  }

  /* Labels */
  .country-label {
    font-family: var(--font-display);
    font-weight: 700;
    fill: var(--color-text-muted);
    pointer-events: none;
  }

  .label-ua {
    font-size: 3px;
    fill: var(--color-accent);
  }

  .label-sm {
    font-size: 2.2px;
  }

  .label-xs {
    font-size: 1.8px;
  }

  /* Connection lines */
  .connection-line {
    stroke: var(--color-accent);
    stroke-width: 0.35;
    stroke-dasharray: 1 0.6;
    opacity: 0.5;
  }

  /* Pulsing dots at border crossings */
  .pulse-dot {
    fill: var(--color-accent);
  }

  .pulse-ring {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 0.3;
    opacity: 0;
  }

  /* Flow particles */
  .flow-particle {
    fill: var(--color-accent);
    opacity: 0;
  }

  /* Animations */
  @media (prefers-reduced-motion: no-preference) {
    .pulse-ring {
      animation: pulseRing 2.5s ease-out infinite;
    }

    .pulse-ring.dot-2 { animation-delay: 0.6s; }
    .pulse-ring.dot-3 { animation-delay: 1.2s; }
    .pulse-ring.dot-4 { animation-delay: 1.8s; }

    .flow-particle {
      animation: flowPulse 3s ease-in-out infinite;
    }

    .flow-2 { animation-delay: 0.7s; }
    .flow-3 { animation-delay: 1.4s; }
    .flow-4 { animation-delay: 2.1s; }

    @keyframes pulseRing {
      0% {
        r: 0.8;
        opacity: 0.7;
      }
      100% {
        r: 3;
        opacity: 0;
      }
    }

    @keyframes flowPulse {
      0%, 100% { opacity: 0; }
      50% { opacity: 0.9; }
    }
  }
</style>
