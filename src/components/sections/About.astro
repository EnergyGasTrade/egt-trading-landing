---
import type { Dictionary } from '../../i18n/useTranslations';

interface Props {
  t: Dictionary;
}

const { t } = Astro.props;
---

<section id="about" class="section-reveal py-24 md:py-32" aria-labelledby="about-heading">
  <div class="mx-auto max-w-[var(--content-max)] px-6">
    <span class="text-xs font-semibold uppercase tracking-widest text-accent">{t.about.sectionLabel}</span>
    <h2 id="about-heading" class="text-heading-1 text-text mt-4 mb-10">
      {t.about.title}
    </h2>

    <div class="max-w-[var(--measure)] space-y-6">
      <p class="text-body-lg text-text-secondary">{t.about.p1}</p>
      <p class="text-body text-text-secondary">{t.about.p2}</p>
      <p class="text-body text-text-secondary">{t.about.p3}</p>
    </div>
  </div>
</section>
