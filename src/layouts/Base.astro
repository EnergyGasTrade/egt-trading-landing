---
import { ClientRouter } from 'astro:transitions';
import type { Locale } from '../i18n/useTranslations';
import { getAlternateUrl } from '../i18n/useTranslations';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  canonicalPath?: string;
}

const { title, description, locale, canonicalPath } = Astro.props;
const currentUrl = Astro.url;
const siteUrl = Astro.site?.origin ?? 'https://egt-trading.com.ua';

const canonicalUrl = `${siteUrl}${canonicalPath ?? currentUrl.pathname}`;
const alternateUk = `${siteUrl}${getAlternateUrl(currentUrl, 'uk')}`;
const alternateEn = `${siteUrl}${getAlternateUrl(currentUrl, 'en')}`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Theme script — MUST run before any render to prevent FOUC */}
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const theme = (stored === 'light' || stored === 'dark')
          ? stored
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />

    {/* Canonical & hreflang */}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="uk" href={alternateUk} />
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="x-default" href={alternateUk} />

    {/* Favicon */}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />

    {/* Font preload */}
    <link
      rel="preload"
      href="/fonts/inter-variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    {/* OG */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}/og/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={locale === 'uk' ? 'uk_UA' : 'en_US'} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {/* JSON-LD */}
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@graph': [
          {
            '@type': 'Organization',
            name: 'EGT Trading',
            legalName: '[COMPANY_LEGAL_NAME_EN]',
            url: siteUrl,
            logo: `${siteUrl}/og/og-image.png`,
            vatID: '[VAT]',
            taxID: '[EDRPOU]',
            address: {
              '@type': 'PostalAddress',
              streetAddress: '[LEGAL_ADDRESS_EN]',
              addressLocality: 'Kyiv',
              addressCountry: 'UA',
            },
            telephone: '[PHONE]',
            email: '[EMAIL]',
            areaServed: [
              { '@type': 'Country', name: 'Ukraine' },
              { '@type': 'Country', name: 'Poland' },
              { '@type': 'Country', name: 'Slovakia' },
              { '@type': 'Country', name: 'Hungary' },
              { '@type': 'Country', name: 'Romania' },
              { '@type': 'Country', name: 'Moldova' },
            ],
          },
          {
            '@type': 'LocalBusiness',
            name: 'EGT Trading',
            legalName: '[COMPANY_LEGAL_NAME_EN]',
            url: siteUrl,
            telephone: '[PHONE]',
            email: '[EMAIL]',
            address: {
              '@type': 'PostalAddress',
              streetAddress: '[OFFICE_ADDRESS_EN]',
              addressLocality: 'Kyiv',
              addressCountry: 'UA',
            },
            openingHours: 'Mo-Fr 09:00-18:00',
          },
        ],
      })}
    />

    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">
      {locale === 'uk' ? 'Перейти до основного вмісту' : 'Skip to main content'}
    </a>
    <slot />
  </body>
</html>
